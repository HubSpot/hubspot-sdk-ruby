        def delete_by_function_type: (
          HubspotSDK::Models::Automation::ActionDeleteByFunctionTypeParams::function_type function_type,
          app_id: Integer,
          definition_id: String,
          ?request_options: HubspotSDK::request_opts
        ) -> nil

        def get: (
          String revision_id,
