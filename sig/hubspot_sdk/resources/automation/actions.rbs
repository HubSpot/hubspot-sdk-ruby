module HubspotSDK
  module Resources
    class Automation
      class Actions
        def create: (
          Integer app_id,
          action_url: String,
          functions: ::Array[HubspotSDK::Automation::PublicActionFunction],
          input_fields: ::Array[HubspotSDK::Automation::PublicInputFieldDefinition],
          labels: ::Hash[Symbol, HubspotSDK::Automation::PublicActionLabels],
          object_types: ::Array[String],
          published: bool,
          ?archived_at: Integer,
          ?execution_rules: ::Array[HubspotSDK::Automation::PublicExecutionTranslationRule],
          ?input_field_dependencies: ::Array[HubspotSDK::Models::Automation::PublicActionDefinitionEgg::input_field_dependency],
          ?object_request_options: HubspotSDK::Automation::PublicObjectRequestOptions,
          ?output_fields: ::Array[HubspotSDK::Automation::OutputFieldDefinition],
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Automation::PublicActionDefinition

        def update: (
          String definition_id,
          app_id: Integer,
          ?action_url: String,
          ?execution_rules: ::Array[HubspotSDK::Automation::PublicExecutionTranslationRule],
          ?input_field_dependencies: ::Array[HubspotSDK::Models::Automation::PublicActionDefinitionPatch::input_field_dependency],
          ?input_fields: ::Array[HubspotSDK::Automation::PublicInputFieldDefinition],
          ?labels: ::Hash[Symbol, HubspotSDK::Automation::PublicActionLabels],
          ?object_request_options: HubspotSDK::Automation::PublicObjectRequestOptions,
          ?object_types: ::Array[String],
          ?output_fields: ::Array[HubspotSDK::Automation::OutputFieldDefinition],
          ?published: bool,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Automation::PublicActionDefinition

        def list: (
          String definition_id,
          app_id: Integer,
          ?after: String,
          ?limit: Integer,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Internal::Page[HubspotSDK::Automation::PublicActionRevision]

        def delete: (
          String function_id,
          app_id: Integer,
          definition_id: String,
          function_type: HubspotSDK::Models::Automation::ActionDeleteParams::function_type,
          ?request_options: HubspotSDK::request_opts
        ) -> nil

        def complete: (
          String callback_id,
          output_fields: ::Hash[Symbol, String],
          typed_outputs: top,
          ?failure_reason_type: String,
          ?request_context: HubspotSDK::Models::Automation::CallbackCompletionRequest::request_context,
          ?request_options: HubspotSDK::request_opts
        ) -> nil

        def complete_batch: (
          inputs: ::Array[HubspotSDK::Automation::CallbackCompletionBatchRequest],
