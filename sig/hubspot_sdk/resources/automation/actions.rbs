          app_id: Integer,
          definition_id: String,
          body: String,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Automation::PublicActionFunctionIdentifier

        def create_requires_object: (
          String definition_id,
          app_id: Integer,
          requires_object: bool,
          ?request_options: HubspotSDK::request_opts
