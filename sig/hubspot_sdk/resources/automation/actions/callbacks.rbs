module HubSpotSDK
  module Resources
    class Automation
      class Actions
        class Callbacks
          def complete: (
            String callback_id,
            output_fields: ::Hash[Symbol, String],
            typed_outputs: top,
            ?failure_reason_type: String,
            ?request_context: HubSpotSDK::Models::Automation::CallbackCompletionRequest::request_context,
            ?request_options: HubSpotSDK::request_opts
          ) -> nil

          def complete_batch: (
            inputs: ::Array[HubSpotSDK::Automation::CallbackCompletionBatchRequest],
            ?request_options: HubSpotSDK::request_opts
          ) -> nil

          def initialize: (client: HubSpotSDK::Client) -> void
        end
      end
    end
  end
end
