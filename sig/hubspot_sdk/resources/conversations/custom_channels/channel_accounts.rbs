module HubspotSDK
  module Resources
    class Conversations
      class CustomChannels
        class ChannelAccounts
          def create: (
            String channel_id,
            authorized: bool,
            inbox_id: String,
            name: String,
            ?delivery_identifier: HubspotSDK::Conversations::PublicDeliveryIdentifier,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Conversations::PublicChannelAccount

          def update: (
            String channel_account_id,
            channel_id: String,
            ?authorized: bool,
            ?name: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Conversations::PublicChannelAccount

          def list: (
            String channel_id,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Conversations::CollectionResponseWithTotalPublicChannelAccountForwardPaging

          def get: (
            String channel_account_id,
            channel_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Conversations::PublicChannelAccount

          def initialize: (client: HubspotSDK::Client) -> void
        end
      end
    end
  end
end
