          ?limit: Integer,
          ?property: String,
          ?sort: ::Array[String],
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Internal::Page[HubspotSDK::Models::Conversations::public_message]

        def get: (
