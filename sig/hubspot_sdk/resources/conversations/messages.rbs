module HubspotSDK
  module Resources
    class Conversations
      class Messages
        def create: (
          String thread_id,
          public_message_egg: HubspotSDK::Models::Conversations::PublicMessageEgg,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Models::Conversations::public_message

        def list: (
          String thread_id,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Conversations::CollectionResponsePublicMessageForwardPaging

        def get: (
          String message_id,
          thread_id: String,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Models::Conversations::public_message

        def get_original_content: (
          String message_id,
          thread_id: String,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Conversations::PublicMessageContent

        def initialize: (client: HubspotSDK::Client) -> void
      end
    end
  end
end
