module HubspotSDK
  module Resources
    class Conversations
      class CustomChannels
        attr_reader channel_accounts: HubspotSDK::Resources::Conversations::CustomChannels::ChannelAccounts

        attr_reader messages: HubspotSDK::Resources::Conversations::CustomChannels::Messages

        def create: (
          capabilities: ::Hash[Symbol, top],
          name: String,
          ?channel_account_connection_redirect_url: String,
          ?channel_description: String,
          ?channel_logo_url: String,
          ?webhook_url: String,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Conversations::PublicChannelIntegrationChannel

        def update: (
          Integer channel_id,
          capabilities: ::Hash[Symbol, top],
          channel_account_connection_redirect_url: top,
          channel_description: top,
          channel_logo_url: top,
          name: top,
          webhook_url: top,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Conversations::PublicChannelIntegrationChannel

        def list: (
          ?after: String,
          ?default_page_length: Integer,
          ?limit: Integer,
          ?sort: ::Array[String],
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Internal::Page[HubspotSDK::Conversations::PublicChannelIntegrationChannel]

        def delete: (
          Integer channel_id,
          ?request_options: HubspotSDK::request_opts
        ) -> nil

        def get: (
          Integer channel_account_id,
          channel_id: Integer,
          ?archived: bool,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Conversations::PublicChannelAccount

        def initialize: (client: HubspotSDK::Client) -> void
      end
    end
  end
end
