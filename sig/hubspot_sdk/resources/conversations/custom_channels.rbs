module HubspotSDK
  module Resources
    class Conversations
      class CustomChannels
        attr_reader channel_account_staging_tokens: HubspotSDK::Resources::Conversations::CustomChannels::ChannelAccountStagingTokens

        attr_reader channel_accounts: HubspotSDK::Resources::Conversations::CustomChannels::ChannelAccounts

        attr_reader messages: HubspotSDK::Resources::Conversations::CustomChannels::Messages

        def create: (
          capabilities: ::Hash[Symbol, top],
          name: String,
          ?channel_account_connection_redirect_url: String,
          ?channel_description: String,
          ?channel_logo_url: String,
          ?webhook_url: String,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Models::Conversations::CustomChannelCreateResponse

        def update: (
          String channel_id,
          capabilities: ::Hash[Symbol, top],
          channel_description: top,
          channel_logo_url: top,
          ?channel_account_connection_redirect_url: top,
          ?name: top,
          ?webhook_url: top,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Models::Conversations::CustomChannelUpdateResponse

        def list: (
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Models::Conversations::CustomChannelListResponse

        def delete: (
          String channel_id,
          ?request_options: HubspotSDK::request_opts
        ) -> nil

        def get: (
          String channel_id,
          ?request_options: HubspotSDK::request_opts
        ) -> HubspotSDK::Models::Conversations::CustomChannelGetResponse

        def initialize: (client: HubspotSDK::Client) -> void
      end
    end
  end
end
