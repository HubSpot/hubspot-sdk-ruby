module HubspotSDK
  module Resources
    class Marketing
      class Events
        class ListAssociations
          def list: (
            String marketing_event_id,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Marketing::CollectionResponseWithTotalPublicList

          def delete: (
            String list_id,
            marketing_event_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def associate: (
            String list_id,
            marketing_event_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def associate_by_external_account: (
            String list_id,
            external_account_id: String,
            external_event_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def delete_by_external_account: (
            String list_id,
