module HubSpotSDK
  module Resources
    class Marketing
      class Campaigns
        class Assets
          def update: (
            String asset_id,
            campaign_guid: String,
            asset_type: String,
            ?request_options: HubSpotSDK::request_opts
          ) -> nil

          def list: (
            String asset_type,
            campaign_guid: String,
            ?after: String,
            ?end_date: String,
            ?limit: String,
            ?start_date: String,
            ?request_options: HubSpotSDK::request_opts
          ) -> HubSpotSDK::Marketing::CollectionResponsePublicCampaignAssetForwardPaging

          def delete: (
            String asset_id,
            campaign_guid: String,
            asset_type: String,
            ?request_options: HubSpotSDK::request_opts
          ) -> nil

          def initialize: (client: HubSpotSDK::Client) -> void
        end
      end
    end
  end
end
