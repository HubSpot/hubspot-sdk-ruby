module HubspotSDK
  module Resources
    class Marketing
      class Transactional
        class SmtpTokens
          def create: (
            campaign_name: String,
            create_contact: bool,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Marketing::SmtpAPITokenView

          def list: (
            ?after: String,
            ?campaign_name: String,
            ?email_campaign_id: String,
            ?limit: Integer,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Internal::Page[HubspotSDK::Marketing::SmtpAPITokenView]

          def delete: (
            String token_id,
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def get: (
            String token_id,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Marketing::SmtpAPITokenView

          def reset_password: (
            String token_id,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Marketing::SmtpAPITokenView

          def initialize: (client: HubspotSDK::Client) -> void
        end
      end
    end
  end
end
