module HubspotSDK
  module Resources
    class Crm
      class Properties
        class Groups
          def create: (
            String object_type,
            label: String,
            name: String,
            ?display_order: Integer,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::PropertyGroup

          def update: (
            String group_name,
            object_type: String,
            ?display_order: Integer,
            ?label: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::PropertyGroup

          def list: (
            String object_type,
            ?locale: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CollectionResponsePropertyGroupNoPaging

          def delete: (
            String group_name,
            object_type: String,
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def get: (
            String group_name,
            object_type: String,
            ?locale: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::PropertyGroup

          def initialize: (client: HubspotSDK::Client) -> void
        end
      end
    end
  end
end
