module HubSpotSDK
  module Resources
    class Crm
      class Associations
        attr_reader batch: HubSpotSDK::Resources::Crm::Associations::Batch

        def list: (
          String to_object_type,
          object_type: String,
          object_id_: String,
          ?after: String,
          ?limit: Integer,
          ?request_options: HubSpotSDK::request_opts
        ) -> HubSpotSDK::Internal::Page[HubSpotSDK::Crm::MultiAssociatedObjectWithLabel]

        def delete: (
          String to_object_id,
          object_type: String,
          object_id_: String,
          to_object_type: String,
          ?request_options: HubSpotSDK::request_opts
        ) -> nil

        def request_high_usage_report: (
          Integer user_id,
          ?request_options: HubSpotSDK::request_opts
        ) -> HubSpotSDK::Crm::ReportCreationResponse

        def search: (
          String object_type,
          after: String,
          filter_groups: ::Array[HubSpotSDK::Crm::FilterGroup],
          limit: Integer,
          properties: ::Array[String],
          sorts: ::Array[String],
          ?query: String,
          ?request_options: HubSpotSDK::request_opts
        ) -> HubSpotSDK::Crm::CollectionResponseWithTotalSimplePublicObject

        def update_association_labels: (
          String to_object_id,
          object_type: String,
          object_id_: String,
          to_object_type: String,
          body: ::Array[HubSpotSDK::AssociationSpec],
          ?request_options: HubSpotSDK::request_opts
        ) -> HubSpotSDK::Crm::LabelsBetweenObjectPair

        def initialize: (client: HubSpotSDK::Client) -> void
      end
    end
  end
end
