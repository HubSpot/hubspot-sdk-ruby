module HubspotSDK
  module Resources
    class CRM
      class Pipelines
        class Stages
          def create: (
            String pipeline_id,
            object_type: String,
            display_order: Integer,
            label: String,
            ?metadata: ::Hash[Symbol, String],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::PipelineStage

          def update: (
            String stage_id,
            object_type: String,
            pipeline_id: String,
            ?archived: bool,
            ?display_order: Integer,
            ?label: String,
            ?metadata: ::Hash[Symbol, String],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::PipelineStage

          def list: (
            String pipeline_id,
            object_type: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::CollectionResponsePipelineStageNoPaging

          def delete: (
            String stage_id,
            object_type: String,
            pipeline_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def get: (
            String stage_id,
            object_type: String,
            pipeline_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::PipelineStage

          def get_audit: (
            String stage_id,
            object_type: String,
            pipeline_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::CollectionResponsePublicAuditInfoNoPaging

          def replace: (
            String stage_id,
            object_type: String,
            pipeline_id: String,
            display_order: Integer,
            label: String,
            ?metadata: ::Hash[Symbol, String],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::PipelineStage

          def initialize: (client: HubspotSDK::Client) -> void
        end
      end
    end
  end
end
