module HubspotSDK
  module Resources
    class Crm
      class Objects
        class Schemas
          def create: (
            associated_objects: ::Array[String],
            labels: HubspotSDK::ObjectTypeDefinitionLabels,
            name: String,
            properties: ::Array[HubspotSDK::Crm::Objects::ObjectTypePropertyCreate],
            required_properties: ::Array[String],
            ?description: String,
            ?primary_display_property: String,
            ?searchable_properties: ::Array[String],
            ?secondary_display_properties: ::Array[String],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Crm::Objects::ObjectSchema

          def update: (
            String object_type,
            ?clear_description: bool,
            ?description: String,
            ?labels: HubspotSDK::ObjectTypeDefinitionLabels,
            ?primary_display_property: String,
            ?required_properties: ::Array[String],
            ?restorable: bool,
            ?searchable_properties: ::Array[String],
            ?secondary_display_properties: ::Array[String],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Crm::Objects::ObjectsSchemasObjectTypeDefinition

          def list: (
            ?archived: bool,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Models::Crm::Objects::SchemaListResponse

          def delete: (
            String object_type,
            ?archived: bool,
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def create_association: (
            String object_type,
            from_object_type_id: String,
            to_object_type_id: String,
            ?name: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Events::AssociationDefinition

          def delete_association: (
            String association_identifier,
            object_type: String,
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def get: (
            String object_type,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Crm::Objects::ObjectSchema

          def initialize: (client: HubspotSDK::Client) -> void
        end
      end
    end
  end
end
