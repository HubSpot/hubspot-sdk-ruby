module HubspotSDK
  module Resources
    class CRM
      class Objects
        class Custom
          attr_reader batch: HubspotSDK::Resources::CRM::Objects::Custom::Batch

          def create: (
            String object_type,
            properties: ::Hash[Symbol, String],
            ?associations: ::Array[HubspotSDK::CRM::PublicAssociationsForObject],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::CreatedResponseSimplePublicObject

          def update: (
            String object_id_,
            object_type: String,
            properties: ::Hash[Symbol, String],
            ?id_property: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::SimplePublicObject

          def list: (
            String object_type,
            ?after: String,
            ?archived: bool,
            ?associations: ::Array[String],
            ?limit: Integer,
            ?properties: ::Array[String],
            ?properties_with_history: ::Array[String],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Internal::Page[HubspotSDK::CRM::SimplePublicObjectWithAssociations]

          def delete: (
            String object_id_,
            object_type: String,
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def get: (
            String object_id_,
            object_type: String,
            ?archived: bool,
            ?associations: ::Array[String],
            ?id_property: String,
            ?properties: ::Array[String],
            ?properties_with_history: ::Array[String],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::SimplePublicObjectWithAssociations

          def merge: (
            String object_type,
            object_id_to_merge: String,
            primary_object_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::SimplePublicObject

          def search: (
            String object_type,
            ?after: String,
            ?filter_groups: ::Array[HubspotSDK::CRM::FilterGroup],
            ?limit: Integer,
            ?properties: ::Array[String],
            ?query: String,
            ?sorts: ::Array[String],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::CRM::CollectionResponseWithTotalSimplePublicObject

          def initialize: (client: HubspotSDK::Client) -> void
        end
      end
    end
  end
end
