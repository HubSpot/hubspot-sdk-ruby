          ) -> HubspotSDK::Crm::BatchResponseSimplePublicObject

          def merge: (
            String object_type,
            object_id_to_merge: String,
            primary_object_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Crm::SimplePublicObject

          def search: (
            String object_type,
            after: String,
            filter_groups: ::Array[HubspotSDK::Crm::FilterGroup],
            limit: Integer,
            properties: ::Array[String],
            sorts: ::Array[String],
            ?query: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Crm::CollectionResponseWithTotalSimplePublicObject

          def upsert: (
            String object_type,
            inputs: ::Array[HubspotSDK::Crm::SimplePublicObjectBatchInputUpsert],
