module HubspotSDK
  module Resources
    class Crm
      class Objects
        class Custom
          def create: (
            String object_type,
            inputs: ::Array[HubspotSDK::Crm::SimplePublicObjectBatchInputForCreate],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Crm::BatchResponseSimplePublicObject

          def update: (
            String object_type,
            inputs: ::Array[HubspotSDK::Crm::SimplePublicObjectBatchInput],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Crm::BatchResponseSimplePublicObject

          def list: (
            String object_type,
            ?after: String,
            ?archived: bool,
            ?associations: ::Array[String],
            ?limit: Integer,
            ?properties: ::Array[String],
            ?properties_with_history: ::Array[String],
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Internal::Page[HubspotSDK::Crm::SimplePublicObjectWithAssociations]

          def delete: (
            String object_type,
            inputs: ::Array[HubspotSDK::Crm::SimplePublicObjectID],
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def get: (
            String object_type,
            inputs: ::Array[HubspotSDK::Crm::SimplePublicObjectID],
            properties: ::Array[String],
            properties_with_history: ::Array[String],
            ?archived: bool,
