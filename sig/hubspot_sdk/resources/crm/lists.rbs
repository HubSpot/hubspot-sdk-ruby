        ) -> HubSpotSDK::Crm::ListSizeAndEditHistoryResponse

        def list_by_search: (
          list_ids: ::Array[String],
          offset: Integer,
          processing_types: ::Array[String],
          ?additional_filter_properties: ::Array[String],
          ?count: Integer,
          ?object_type_id: String,
          ?query: String,
          ?sort: String,
