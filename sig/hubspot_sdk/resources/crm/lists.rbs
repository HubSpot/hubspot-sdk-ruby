module HubSpotSDK
  module Resources
    class Crm
      class Lists
        def create: (
          name: String,
          object_type_id: String,
          processing_type: String,
          ?custom_properties: ::Hash[Symbol, String],
          ?filter_branch: HubSpotSDK::Models::Crm::ListCreateRequest::filter_branch,
          ?list_folder_id: Integer,
          ?list_permissions: HubSpotSDK::Crm::PublicListPermissions,
          ?membership_settings: HubSpotSDK::Crm::PublicMembershipSettings,
          ?request_options: HubSpotSDK::request_opts
        ) -> HubSpotSDK::Crm::ListCreateResponse

        def list: (
          ?include_filters: bool,
