        ) -> HubSpotSDK::Crm::BatchResponseRecordIDWithMemberships

        def create_folder: (
          name: String,
          ?parent_folder_id: String,
          ?request_options: HubSpotSDK::request_opts
        ) -> HubSpotSDK::Crm::ListFolderCreateResponse

        def create_id_mapping: (
          body: ::Array[String],
