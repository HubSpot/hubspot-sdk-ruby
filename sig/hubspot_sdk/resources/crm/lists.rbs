        ) -> HubSpotSDK::Crm::ListFetchResponse

        def get_id_mapping: (
          ?legacy_list_id: String,
          ?request_options: HubSpotSDK::request_opts
        ) -> HubSpotSDK::Crm::PublicMigrationMapping

        def get_memberships_join_order: (
