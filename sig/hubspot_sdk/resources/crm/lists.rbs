        ) -> HubSpotSDK::Crm::PublicBatchMigrationMapping

        def delete_folder: (
          String folder_id,
          ?request_options: HubSpotSDK::request_opts
        ) -> nil

        def delete_memberships: (
          String list_id,
          ?request_options: HubSpotSDK::request_opts
        ) -> nil

        def get: (
          String list_id,
