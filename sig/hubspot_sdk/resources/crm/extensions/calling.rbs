module HubspotSDK
  module Resources
    class Crm
      class Extensions
        class Calling
          attr_reader channel_connection_settings: HubspotSDK::Resources::Crm::Extensions::Calling::ChannelConnectionSettings

          attr_reader recording_settings: HubspotSDK::Resources::Crm::Extensions::Calling::RecordingSettings

          attr_reader settings: HubspotSDK::Resources::Crm::Extensions::Calling::Settings

          attr_reader transcripts: HubspotSDK::Resources::Crm::Extensions::Calling::Transcripts

          def initialize: (client: HubspotSDK::Client) -> void
        end
      end
    end
  end
end
