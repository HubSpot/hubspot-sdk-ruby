module HubspotSDK
  module Resources
    class Crm
      class Extensions
        class Calling
          class Transcripts
            def create: (
              engagement_id: Integer,
              transcript_create_utterances: ::Array[HubspotSDK::Crm::Extensions::Calling::TranscriptCreateUtterance],
              ?request_options: HubspotSDK::request_opts
            ) -> HubspotSDK::Crm::Extensions::Calling::TranscriptCreateResponse

            def delete: (
              String transcript_id,
              ?request_options: HubspotSDK::request_opts
            ) -> nil

            def get: (
              String transcript_id,
              ?request_options: HubspotSDK::request_opts
            ) -> HubspotSDK::Crm::Extensions::Calling::TranscriptResponse

