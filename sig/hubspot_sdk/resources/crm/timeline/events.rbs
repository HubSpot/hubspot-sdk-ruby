module HubspotSDK
  module Resources
    class Crm
      class Timeline
        class Events
          def create: (
            event_template_id: String,
            tokens: ::Hash[Symbol, String],
            ?id: String,
            ?domain: String,
            ?email: String,
            ?extra_data: top,
            ?object_id_: String,
            ?timeline_i_frame: HubspotSDK::Crm::TimelineEventIFrame,
            ?timestamp: Time,
            ?utk: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Crm::TimelineEventResponse

          def batch_create: (
            inputs: ::Array[HubspotSDK::Crm::TimelineEvent],
            ?request_options: HubspotSDK::request_opts
          ) -> nil

          def get: (
            String event_id,
            event_template_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Crm::TimelineEventResponse

          def get_detail: (
            String event_id,
            event_template_id: String,
            ?request_options: HubspotSDK::request_opts
          ) -> HubspotSDK::Crm::EventDetail

          def initialize: (client: HubspotSDK::Client) -> void
        end
      end
    end
  end
end
