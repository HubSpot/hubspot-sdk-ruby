module HubspotSDK
  module Resources
    class Conversations
      attr_reader actors: HubspotSDK::Resources::Conversations::Actors

      attr_reader channel_accounts: HubspotSDK::Resources::Conversations::ChannelAccounts

      attr_reader channels: HubspotSDK::Resources::Conversations::Channels

      attr_reader custom_channels: HubspotSDK::Resources::Conversations::CustomChannels

      attr_reader inboxes: HubspotSDK::Resources::Conversations::Inboxes

      attr_reader messages: HubspotSDK::Resources::Conversations::Messages

      attr_reader threads: HubspotSDK::Resources::Conversations::Threads

      attr_reader visitor_identification: HubspotSDK::Resources::Conversations::VisitorIdentification

      def initialize: (client: HubspotSDK::Client) -> void
    end
  end
end
