module HubSpotSDK
  module Models
    module Scheduler
      type external_reminder =
        {
          number_of_time_units: Integer,
          time_unit: HubSpotSDK::Models::Scheduler::ExternalReminder::time_unit
        }

      class ExternalReminder < HubSpotSDK::Internal::Type::BaseModel
        attr_accessor number_of_time_units: Integer

        attr_accessor time_unit: HubSpotSDK::Models::Scheduler::ExternalReminder::time_unit

        def initialize: (
          number_of_time_units: Integer,
          time_unit: HubSpotSDK::Models::Scheduler::ExternalReminder::time_unit
        ) -> void

        def to_hash: -> {
          number_of_time_units: Integer,
          time_unit: HubSpotSDK::Models::Scheduler::ExternalReminder::time_unit
        }

        type time_unit = :DAYS | :HOURS | :MINUTES | :WEEKS

        module TimeUnit
          extend HubSpotSDK::Internal::Type::Enum

          DAYS: :DAYS
          HOURS: :HOURS
          MINUTES: :MINUTES
          WEEKS: :WEEKS

          def self?.values: -> ::Array[HubSpotSDK::Models::Scheduler::ExternalReminder::time_unit]
        end
      end
    end
  end
end
