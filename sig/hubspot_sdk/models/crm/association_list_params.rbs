module HubSpotSDK
  module Models
    module Crm
      type association_list_params =
        {
          object_type: String,
          object_id_: String,
          to_object_type: String,
          after: String,
          limit: Integer
        }
        & HubSpotSDK::Internal::Type::request_parameters

      class AssociationListParams < HubSpotSDK::Internal::Type::BaseModel
        extend HubSpotSDK::Internal::Type::RequestParameters::Converter
        include HubSpotSDK::Internal::Type::RequestParameters

        attr_accessor object_type: String

        attr_accessor object_id_: String

        attr_accessor to_object_type: String

        attr_reader after: String?

        def after=: (String) -> String

        attr_reader limit: Integer?

        def limit=: (Integer) -> Integer

        def initialize: (
          object_type: String,
          object_id_: String,
          to_object_type: String,
          ?after: String,
          ?limit: Integer,
          ?request_options: HubSpotSDK::request_opts
        ) -> void

        def to_hash: -> {
          object_type: String,
          object_id_: String,
          to_object_type: String,
          after: String,
          limit: Integer,
          request_options: HubSpotSDK::RequestOptions
        }
      end
    end
  end
end
