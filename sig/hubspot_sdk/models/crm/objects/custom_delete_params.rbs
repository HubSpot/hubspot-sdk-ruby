module HubspotSDK
  module Models
    module Crm
      module Objects
        type custom_delete_params =
          { object_type: String, object_id_: String }
          & HubspotSDK::Internal::Type::request_parameters

        class CustomDeleteParams < HubspotSDK::Internal::Type::BaseModel
          extend HubspotSDK::Internal::Type::RequestParameters::Converter
          include HubspotSDK::Internal::Type::RequestParameters

          attr_accessor object_type: String

          attr_accessor object_id_: String

          def initialize: (
            object_type: String,
            object_id_: String,
            ?request_options: HubspotSDK::request_opts
          ) -> void

          def to_hash: -> {
            object_type: String,
            object_id_: String,
            request_options: HubspotSDK::RequestOptions
          }
        end
      end
    end
  end
end
