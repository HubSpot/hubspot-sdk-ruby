module HubSpotSDK
  module Models
    module Webhooks
      type settings_change_request =
        {
          target_url: String,
          throttling: HubSpotSDK::Webhooks::ThrottlingSettings
        }

      class SettingsChangeRequest < HubSpotSDK::Internal::Type::BaseModel
        attr_accessor target_url: String

        attr_accessor throttling: HubSpotSDK::Webhooks::ThrottlingSettings

        def initialize: (
          target_url: String,
          throttling: HubSpotSDK::Webhooks::ThrottlingSettings
        ) -> void

        def to_hash: -> {
          target_url: String,
          throttling: HubSpotSDK::Webhooks::ThrottlingSettings
        }
      end
    end
  end
end
