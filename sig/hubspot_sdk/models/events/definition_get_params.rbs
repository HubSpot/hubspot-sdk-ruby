module HubSpotSDK
  module Models
    module Events
      type definition_get_params =
        { event_name: String } & HubSpotSDK::Internal::Type::request_parameters

      class DefinitionGetParams < HubSpotSDK::Internal::Type::BaseModel
        extend HubSpotSDK::Internal::Type::RequestParameters::Converter
        include HubSpotSDK::Internal::Type::RequestParameters

        attr_accessor event_name: String

        def initialize: (
          event_name: String,
          ?request_options: HubSpotSDK::request_opts
        ) -> void

        def to_hash: -> {
          event_name: String,
          request_options: HubSpotSDK::RequestOptions
        }
      end
    end
  end
end
