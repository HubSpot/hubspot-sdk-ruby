        month: Integer,
        reference_type: HubspotSDK::Models::PublicYearReference::reference_type,
        hour: Integer,
        millisecond: Integer,
        minute: Integer,
        second: Integer
      }

    class PublicYearReference < HubspotSDK::Internal::Type::BaseModel
