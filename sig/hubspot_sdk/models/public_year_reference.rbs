      attr_accessor month: Integer

      attr_accessor reference_type: HubspotSDK::Models::PublicYearReference::reference_type

      attr_reader hour: Integer?

      def hour=: (Integer) -> Integer

      attr_reader millisecond: Integer?

      def millisecond=: (Integer) -> Integer

      attr_reader minute: Integer?

      def minute=: (Integer) -> Integer

      attr_reader second: Integer?

