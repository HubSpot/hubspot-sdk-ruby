module HubspotSDK
  module Models
    module Settings
      type tax_rate_get_response =
        {
          id: String,
          active: bool,
          created_at: Time,
          label: String,
          name: String,
          percentage_rate: Float,
          updated_at: Time
        }

      class TaxRateGetResponse < HubspotSDK::Internal::Type::BaseModel
