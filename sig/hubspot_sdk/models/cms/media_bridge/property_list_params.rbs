module HubspotSDK
  module Models
    module Cms
      module MediaBridge
        type property_list_params =
          { app_id: Integer, archived: bool, properties: String }
          & HubspotSDK::Internal::Type::request_parameters

        class PropertyListParams < HubspotSDK::Internal::Type::BaseModel
          extend HubspotSDK::Internal::Type::RequestParameters::Converter
          include HubspotSDK::Internal::Type::RequestParameters

          attr_accessor app_id: Integer

          attr_reader archived: bool?

          def archived=: (bool) -> bool

          attr_reader properties: String?

          def properties=: (String) -> String

          def initialize: (
            app_id: Integer,
            ?archived: bool,
            ?properties: String,
            ?request_options: HubspotSDK::request_opts
          ) -> void

          def to_hash: -> {
            app_id: Integer,
            archived: bool,
            properties: String,
            request_options: HubspotSDK::RequestOptions
          }
        end
      end
    end
  end
end
