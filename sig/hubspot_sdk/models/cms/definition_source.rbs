module HubspotSDK
  module Models
    module Cms
      type definition_source = { type: String, name: String }

      class DefinitionSource < HubspotSDK::Internal::Type::BaseModel
        attr_accessor type: String

        attr_reader name: String?

        def name=: (String) -> String

        def initialize: (type: String, ?name: String) -> void

        def to_hash: -> { type: String, name: String }
      end
    end
  end
end
