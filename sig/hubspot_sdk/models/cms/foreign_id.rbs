module HubSpotSDK
  module Models
    module Cms
      type foreign_id = { id: String, name: String, type: String }

      class ForeignID < HubSpotSDK::Internal::Type::BaseModel
        attr_accessor id: String

        attr_accessor name: String

        attr_accessor type: String

        def initialize: (id: String, name: String, type: String) -> void

        def to_hash: -> { id: String, name: String, type: String }
      end
    end
  end
end
