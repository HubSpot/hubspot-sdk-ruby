module HubspotSDK
  module Models
    module Cms
      type media_played_percentage_event =
        {
          contact_id: Integer,
          media_bridge_id: Integer,
          media_bridge_object_coordinates: String,
          media_bridge_object_type_id: String,
          media_name: String,
          media_type: HubspotSDK::Models::Cms::MediaPlayedPercentageEvent::media_type,
          occurred_timestamp: Integer,
          played_percent: Integer,
          portal_id: Integer,
          provider_id: Integer,
          session_id: String,
          media_url: String,
          page_id: Integer,
          page_name: String,
          page_object_coordinates: String,
          page_url: String
        }

      class MediaPlayedPercentageEvent < HubspotSDK::Internal::Type::BaseModel
        attr_accessor contact_id: Integer

        attr_accessor media_bridge_id: Integer

        attr_accessor media_bridge_object_coordinates: String

        attr_accessor media_bridge_object_type_id: String

        attr_accessor media_name: String

        attr_accessor media_type: HubspotSDK::Models::Cms::MediaPlayedPercentageEvent::media_type

        attr_accessor occurred_timestamp: Integer

        attr_accessor played_percent: Integer

        attr_accessor portal_id: Integer

        attr_accessor provider_id: Integer

        attr_accessor session_id: String

        attr_reader media_url: String?

        def media_url=: (String) -> String

        attr_reader page_id: Integer?

        def page_id=: (Integer) -> Integer

        attr_reader page_name: String?

        def page_name=: (String) -> String

        attr_reader page_object_coordinates: String?

        def page_object_coordinates=: (String) -> String

        attr_reader page_url: String?

        def page_url=: (String) -> String

        def initialize: (
          contact_id: Integer,
          media_bridge_id: Integer,
          media_bridge_object_coordinates: String,
          media_bridge_object_type_id: String,
          media_name: String,
          media_type: HubspotSDK::Models::Cms::MediaPlayedPercentageEvent::media_type,
          occurred_timestamp: Integer,
          played_percent: Integer,
          portal_id: Integer,
          provider_id: Integer,
          session_id: String,
          ?media_url: String,
          ?page_id: Integer,
          ?page_name: String,
          ?page_object_coordinates: String,
          ?page_url: String
        ) -> void

        def to_hash: -> {
          contact_id: Integer,
          media_bridge_id: Integer,
          media_bridge_object_coordinates: String,
          media_bridge_object_type_id: String,
          media_name: String,
          media_type: HubspotSDK::Models::Cms::MediaPlayedPercentageEvent::media_type,
          occurred_timestamp: Integer,
