          provider_id: Integer,
          session_id: String,
          media_url: String,
          page_id: Integer,
          page_name: String,
          page_object_coordinates: String,
          page_url: String
        }

        type media_type = :VIDEO | :AUDIO | :DOCUMENT | :OTHER | :IMAGE

        module MediaType
          extend HubspotSDK::Internal::Type::Enum

          VIDEO: :VIDEO
          AUDIO: :AUDIO
          DOCUMENT: :DOCUMENT
