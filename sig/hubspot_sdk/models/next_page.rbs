module HubspotSDK
  module Models
    type next_page = { after: String, link: String }

    class NextPage < HubspotSDK::Internal::Type::BaseModel
      attr_accessor after: String

      attr_reader link: String?

      def link=: (String) -> String

      def initialize: (after: String, ?link: String) -> void

      def to_hash: -> { after: String, link: String }
    end
  end
end
