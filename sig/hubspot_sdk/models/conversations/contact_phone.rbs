module HubSpotSDK
  module Models
    module Conversations
      type contact_phone =
        {
          phone: String,
          type: HubSpotSDK::Models::Conversations::ContactPhone::type_
        }

      class ContactPhone < HubSpotSDK::Internal::Type::BaseModel
        attr_accessor phone: String

        attr_reader type: HubSpotSDK::Models::Conversations::ContactPhone::type_?

        def type=: (
          HubSpotSDK::Models::Conversations::ContactPhone::type_
        ) -> HubSpotSDK::Models::Conversations::ContactPhone::type_

        def initialize: (
          phone: String,
          ?type: HubSpotSDK::Models::Conversations::ContactPhone::type_
        ) -> void

        def to_hash: -> {
          phone: String,
          type: HubSpotSDK::Models::Conversations::ContactPhone::type_
        }

        type type_ = :CELL | :HOME | :MAIN | :WORK

        module Type
          extend HubSpotSDK::Internal::Type::Enum

          CELL: :CELL
          HOME: :HOME
          MAIN: :MAIN
          WORK: :WORK

          def self?.values: -> ::Array[HubSpotSDK::Models::Conversations::ContactPhone::type_]
        end
      end
    end
  end
