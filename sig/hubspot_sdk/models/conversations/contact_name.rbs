module HubSpotSDK
  module Models
    module Conversations
      type contact_name =
        {
          first_name: String,
          last_name: String,
          middle_name: String,
          prefix: String,
          suffix: String
        }

      class ContactName < HubSpotSDK::Internal::Type::BaseModel
        attr_reader first_name: String?

        def first_name=: (String) -> String

        attr_reader last_name: String?

        def last_name=: (String) -> String

        attr_reader middle_name: String?

        def middle_name=: (String) -> String

        attr_reader prefix: String?

        def prefix=: (String) -> String

        attr_reader suffix: String?

        def suffix=: (String) -> String

        def initialize: (
          ?first_name: String,
          ?last_name: String,
          ?middle_name: String,
          ?prefix: String,
          ?suffix: String
        ) -> void

        def to_hash: -> {
          first_name: String,
          last_name: String,
          middle_name: String,
          prefix: String,
          suffix: String
        }
      end
    end
  end
end
