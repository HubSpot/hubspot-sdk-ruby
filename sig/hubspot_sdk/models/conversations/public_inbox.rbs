module HubspotSDK
  module Models
    module Conversations
      type public_inbox =
        {
          archived: bool,
          type: String,
          id: String,
          archived_at: Time,
          created_at: Time,
          name: String,
          updated_at: Time
        }

      class PublicInbox < HubspotSDK::Internal::Type::BaseModel
        attr_accessor archived: bool

        attr_accessor type: String

        attr_reader id: String?

        def id=: (String) -> String

        attr_reader archived_at: Time?

        def archived_at=: (Time) -> Time

        attr_reader created_at: Time?

        def created_at=: (Time) -> Time

        attr_reader name: String?

        def name=: (String) -> String

        attr_reader updated_at: Time?

        def updated_at=: (Time) -> Time

        def initialize: (
          archived: bool,
          type: String,
          ?id: String,
          ?archived_at: Time,
          ?created_at: Time,
          ?name: String,
          ?updated_at: Time
        ) -> void

        def to_hash: -> {
          archived: bool,
          type: String,
          id: String,
          archived_at: Time,
          created_at: Time,
          name: String,
          updated_at: Time
        }
      end
    end
  end
end
