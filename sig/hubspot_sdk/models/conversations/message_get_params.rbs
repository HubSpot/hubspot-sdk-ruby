module HubspotSDK
  module Models
    module Conversations
      type message_get_params =
        { thread_id: String } & HubspotSDK::Internal::Type::request_parameters

      class MessageGetParams < HubspotSDK::Internal::Type::BaseModel
        extend HubspotSDK::Internal::Type::RequestParameters::Converter
        include HubspotSDK::Internal::Type::RequestParameters

        attr_accessor thread_id: String

        def initialize: (
          thread_id: String,
          ?request_options: HubspotSDK::request_opts
        ) -> void

        def to_hash: -> {
          thread_id: String,
          request_options: HubspotSDK::RequestOptions
        }
      end
    end
  end
end
