module HubSpotSDK
  module Models
    module Conversations
      type public_sender =
        {
          actor_id: String,
          delivery_identifier: HubSpotSDK::Conversations::PublicDeliveryIdentifier,
          name: String,
          sender_field: String
        }

      class PublicSender < HubSpotSDK::Internal::Type::BaseModel
        attr_reader actor_id: String?

        def actor_id=: (String) -> String

        attr_reader delivery_identifier: HubSpotSDK::Conversations::PublicDeliveryIdentifier?

        def delivery_identifier=: (
          HubSpotSDK::Conversations::PublicDeliveryIdentifier
        ) -> HubSpotSDK::Conversations::PublicDeliveryIdentifier

        attr_reader name: String?

        def name=: (String) -> String

        attr_reader sender_field: String?

        def sender_field=: (String) -> String

        def initialize: (
          ?actor_id: String,
          ?delivery_identifier: HubSpotSDK::Conversations::PublicDeliveryIdentifier,
          ?name: String,
          ?sender_field: String
        ) -> void

        def to_hash: -> {
          actor_id: String,
          delivery_identifier: HubSpotSDK::Conversations::PublicDeliveryIdentifier,
          name: String,
          sender_field: String
        }
      end
    end
  end
end
