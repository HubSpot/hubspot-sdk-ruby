module HubspotSDK
  module Models
    module Conversations
      type public_file =
        {
          file_id: String,
          file_usage_type: String,
          type: HubspotSDK::Models::Conversations::PublicFile::type_,
          name: String,
          url: String
        }

      class PublicFile < HubspotSDK::Internal::Type::BaseModel
        attr_accessor file_id: String

        attr_accessor file_usage_type: String

        attr_accessor type: HubspotSDK::Models::Conversations::PublicFile::type_

        attr_reader name: String?

        def name=: (String) -> String

        attr_reader url: String?

        def url=: (String) -> String

        def initialize: (
          file_id: String,
          file_usage_type: String,
          type: HubspotSDK::Models::Conversations::PublicFile::type_,
          ?name: String,
          ?url: String
        ) -> void

        def to_hash: -> {
          file_id: String,
          file_usage_type: String,
          type: HubspotSDK::Models::Conversations::PublicFile::type_,
          name: String,
          url: String
        }

        type type_ = :FILE

        module Type
          extend HubspotSDK::Internal::Type::Enum

          FILE: :FILE

          def self?.values: -> ::Array[HubspotSDK::Models::Conversations::PublicFile::type_]
        end
      end
    end
  end
end
