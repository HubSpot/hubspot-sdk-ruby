module HubspotSDK
  module Models
    module Conversations
      type public_channel_account =
        {
          archived: bool,
          id: String,
          active: bool,
          archived_at: Time,
          authorized: bool,
          channel_id: String,
          created_at: Time,
          delivery_identifier: HubspotSDK::Conversations::PublicDeliveryIdentifier,
          inbox_id: String,
          name: String
        }

      class PublicChannelAccount < HubspotSDK::Internal::Type::BaseModel
        attr_accessor archived: bool

        attr_reader id: String?

        def id=: (String) -> String

        attr_reader active: bool?

        def active=: (bool) -> bool

        attr_reader archived_at: Time?

        def archived_at=: (Time) -> Time

        attr_reader authorized: bool?

        def authorized=: (bool) -> bool

        attr_reader channel_id: String?

        def channel_id=: (String) -> String

        attr_reader created_at: Time?

        def created_at=: (Time) -> Time

        attr_reader delivery_identifier: HubspotSDK::Conversations::PublicDeliveryIdentifier?

        def delivery_identifier=: (
          HubspotSDK::Conversations::PublicDeliveryIdentifier
        ) -> HubspotSDK::Conversations::PublicDeliveryIdentifier

        attr_reader inbox_id: String?

        def inbox_id=: (String) -> String

        attr_reader name: String?

        def name=: (String) -> String

        def initialize: (
          archived: bool,
          ?id: String,
          ?active: bool,
          ?archived_at: Time,
          ?authorized: bool,
          ?channel_id: String,
          ?created_at: Time,
          ?delivery_identifier: HubspotSDK::Conversations::PublicDeliveryIdentifier,
          ?inbox_id: String,
          ?name: String
        ) -> void

        def to_hash: -> {
          archived: bool,
          id: String,
          active: bool,
          archived_at: Time,
          authorized: bool,
          channel_id: String,
          created_at: Time,
          delivery_identifier: HubspotSDK::Conversations::PublicDeliveryIdentifier,
          inbox_id: String,
          name: String
        }
      end
    end
  end
end
