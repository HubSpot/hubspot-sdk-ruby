module HubSpotSDK
  module Models
    module Conversations
      type public_channel_account =
        {
          id: String,
          active: bool,
          archived: bool,
          authorized: bool,
          channel_id: String,
          created_at: Time,
          inbox_id: String,
          name: String,
          archived_at: Time,
          delivery_identifier: HubSpotSDK::Conversations::PublicDeliveryIdentifier
        }

      class PublicChannelAccount < HubSpotSDK::Internal::Type::BaseModel
        attr_accessor id: String

        attr_accessor active: bool

        attr_accessor archived: bool

        attr_accessor authorized: bool

        attr_accessor channel_id: String

        attr_accessor created_at: Time

        attr_accessor inbox_id: String

        attr_accessor name: String

        attr_reader archived_at: Time?

        def archived_at=: (Time) -> Time

        attr_reader delivery_identifier: HubSpotSDK::Conversations::PublicDeliveryIdentifier?

        def delivery_identifier=: (
          HubSpotSDK::Conversations::PublicDeliveryIdentifier
        ) -> HubSpotSDK::Conversations::PublicDeliveryIdentifier

        def initialize: (
          id: String,
          active: bool,
          archived: bool,
          authorized: bool,
          channel_id: String,
          created_at: Time,
          inbox_id: String,
          name: String,
          ?archived_at: Time,
          ?delivery_identifier: HubSpotSDK::Conversations::PublicDeliveryIdentifier
        ) -> void

        def to_hash: -> {
          id: String,
          active: bool,
          archived: bool,
          authorized: bool,
          channel_id: String,
          created_at: Time,
          inbox_id: String,
          name: String,
          archived_at: Time,
          delivery_identifier: HubSpotSDK::Conversations::PublicDeliveryIdentifier
        }
      end
    end
  end
end
