module HubspotSDK
  module Models
    module Conversations
      type contact_address =
        {
          city: String,
          country: String,
          country_code: String,
          state: String,
          street: String,
          type: HubspotSDK::Models::Conversations::ContactAddress::type_,
          zip: String
        }

      class ContactAddress < HubspotSDK::Internal::Type::BaseModel
        attr_reader city: String?

        def city=: (String) -> String

        attr_reader country: String?

        def country=: (String) -> String

        attr_reader country_code: String?

        def country_code=: (String) -> String

        attr_reader state: String?

        def state=: (String) -> String

        attr_reader street: String?

        def street=: (String) -> String

        attr_reader type: HubspotSDK::Models::Conversations::ContactAddress::type_?

        def type=: (
          HubspotSDK::Models::Conversations::ContactAddress::type_
        ) -> HubspotSDK::Models::Conversations::ContactAddress::type_

        attr_reader zip: String?

        def zip=: (String) -> String

        def initialize: (
          ?city: String,
          ?country: String,
          ?country_code: String,
          ?state: String,
          ?street: String,
          ?type: HubspotSDK::Models::Conversations::ContactAddress::type_,
          ?zip: String
        ) -> void

        def to_hash: -> {
          city: String,
          country: String,
          country_code: String,
          state: String,
          street: String,
          type: HubspotSDK::Models::Conversations::ContactAddress::type_,
          zip: String
        }

        type type_ = :HOME | :WORK

        module Type
          extend HubspotSDK::Internal::Type::Enum

          HOME: :HOME
          WORK: :WORK

          def self?.values: -> ::Array[HubspotSDK::Models::Conversations::ContactAddress::type_]
        end
      end
    end
  end
end
