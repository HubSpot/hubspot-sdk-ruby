module HubSpotSDK
  module Models
    module Conversations
      type contact_org = { company: String, department: String, title: String }

      class ContactOrg < HubSpotSDK::Internal::Type::BaseModel
        attr_reader company: String?

        def company=: (String) -> String

        attr_reader department: String?

        def department=: (String) -> String

        attr_reader title: String?

        def title=: (String) -> String

        def initialize: (
          ?company: String,
          ?department: String,
          ?title: String
        ) -> void

        def to_hash: -> { company: String, department: String, title: String }
      end
    end
  end
end
