module HubSpotSDK
  module Models
    module Conversations
      module CustomChannels
        type message_get_params =
          { channel_id: Integer, message_id: String }
          & HubSpotSDK::Internal::Type::request_parameters

        class MessageGetParams < HubSpotSDK::Internal::Type::BaseModel
          extend HubSpotSDK::Internal::Type::RequestParameters::Converter
          include HubSpotSDK::Internal::Type::RequestParameters

          attr_accessor channel_id: Integer

          attr_accessor message_id: String

          def initialize: (
            channel_id: Integer,
            message_id: String,
            ?request_options: HubSpotSDK::request_opts
          ) -> void

          def to_hash: -> {
            channel_id: Integer,
            message_id: String,
            request_options: HubSpotSDK::RequestOptions
          }
        end
      end
    end
  end
end
