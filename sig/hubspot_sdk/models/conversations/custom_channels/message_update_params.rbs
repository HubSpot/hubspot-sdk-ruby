module HubSpotSDK
  module Models
    module Conversations
      module CustomChannels
        type message_update_params =
          { channel_id: Integer, message_id: String }
          & HubSpotSDK::Internal::Type::request_parameters

        class MessageUpdateParams < HubSpotSDK::Models::Conversations::PublicChannelIntegrationMessageUpdateRequest
          extend HubSpotSDK::Internal::Type::RequestParameters::Converter
          include HubSpotSDK::Internal::Type::RequestParameters

          def channel_id: -> Integer

          def channel_id=: (Integer _) -> Integer

          def message_id: -> String

          def message_id=: (String _) -> String

          def initialize: (
            channel_id: Integer,
            message_id: String,
            ?request_options: HubSpotSDK::request_opts
          ) -> void

          def to_hash: -> {
            channel_id: Integer,
            message_id: String,
            request_options: HubSpotSDK::RequestOptions
          }
        end
      end
    end
  end
end
