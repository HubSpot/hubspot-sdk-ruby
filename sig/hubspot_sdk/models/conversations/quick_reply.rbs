module HubspotSDK
  module Models
    module Conversations
      type quick_reply = { value: String, value_type: String, label: String }

      class QuickReply < HubspotSDK::Internal::Type::BaseModel
        attr_accessor value: String

        attr_accessor value_type: String

        attr_reader label: String?

        def label=: (String) -> String

        def initialize: (
          value: String,
          value_type: String,
          ?label: String
        ) -> void

        def to_hash: -> { value: String, value_type: String, label: String }
      end
    end
  end
end
