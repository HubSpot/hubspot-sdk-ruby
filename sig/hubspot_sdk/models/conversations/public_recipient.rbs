module HubspotSDK
  module Models
    module Conversations
      type public_recipient =
        {
          delivery_identifier: HubspotSDK::Conversations::PublicDeliveryIdentifier,
          actor_id: String,
          name: String,
          recipient_field: String
        }

      class PublicRecipient < HubspotSDK::Internal::Type::BaseModel
        attr_accessor delivery_identifier: HubspotSDK::Conversations::PublicDeliveryIdentifier

        attr_reader actor_id: String?

        def actor_id=: (String) -> String

        attr_reader name: String?

        def name=: (String) -> String

        attr_reader recipient_field: String?

        def recipient_field=: (String) -> String

        def initialize: (
          delivery_identifier: HubspotSDK::Conversations::PublicDeliveryIdentifier,
          ?actor_id: String,
          ?name: String,
          ?recipient_field: String
        ) -> void

        def to_hash: -> {
          delivery_identifier: HubspotSDK::Conversations::PublicDeliveryIdentifier,
          actor_id: String,
          name: String,
          recipient_field: String
        }
      end
    end
  end
end
