module HubSpotSDK
  module Models
    module Marketing
      type public_webversion_details =
        {
          domain: String,
          enabled: bool,
          expires_at: Time,
          is_page_redirected: bool,
          meta_description: String,
          page_expiry_enabled: bool,
          redirect_to_page_id: String,
          redirect_to_url: String,
          slug: String,
          title: String,
          url: String
        }

      class PublicWebversionDetails < HubSpotSDK::Internal::Type::BaseModel
        attr_reader domain: String?

        def domain=: (String) -> String

