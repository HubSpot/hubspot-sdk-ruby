        attr_reader redirect_to_url: String?

        def redirect_to_url=: (String) -> String

        attr_reader slug: String?

        def slug=: (String) -> String

        attr_reader title: String?

        def title=: (String) -> String

        attr_reader url: String?

        def url=: (String) -> String

        def initialize: (
          ?domain: String,
          ?enabled: bool,
          ?expires_at: Time,
          ?is_page_redirected: bool,
          ?meta_description: String,
          ?page_expiry_enabled: bool,
          ?redirect_to_page_id: String,
          ?redirect_to_url: String,
          ?slug: String,
          ?title: String,
          ?url: String
        ) -> void

        def to_hash: -> {
          domain: String,
          enabled: bool,
          expires_at: Time,
          is_page_redirected: bool,
          meta_description: String,
          page_expiry_enabled: bool,
          redirect_to_page_id: String,
