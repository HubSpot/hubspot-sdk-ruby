module HubspotSDK
  module Models
    module Marketing
      type crm_property_wrapper = { name: String, value: String }

      class CRMPropertyWrapper < HubspotSDK::Internal::Type::BaseModel
        attr_accessor name: String

        attr_accessor value: String

        def initialize: (name: String, value: String) -> void

        def to_hash: -> { name: String, value: String }
      end
    end
  end
end
