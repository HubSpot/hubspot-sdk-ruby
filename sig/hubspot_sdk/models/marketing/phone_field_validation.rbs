module HubspotSDK
  module Models
    module Marketing
      type phone_field_validation =
        { max_allowed_digits: Integer, min_allowed_digits: Integer }

      class PhoneFieldValidation < HubspotSDK::Internal::Type::BaseModel
        attr_accessor max_allowed_digits: Integer

        attr_accessor min_allowed_digits: Integer

        def initialize: (
          max_allowed_digits: Integer,
          min_allowed_digits: Integer
        ) -> void

        def to_hash: -> {
          max_allowed_digits: Integer,
          min_allowed_digits: Integer
        }
      end
    end
  end
end
