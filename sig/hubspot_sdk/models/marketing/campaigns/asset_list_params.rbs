module HubSpotSDK
  module Models
    module Marketing
      module Campaigns
        type asset_list_params =
          {
            campaign_guid: String,
            asset_type: String,
            after: String,
            end_date: String,
            limit: String,
            start_date: String
          }
          & HubSpotSDK::Internal::Type::request_parameters

        class AssetListParams < HubSpotSDK::Internal::Type::BaseModel
          extend HubSpotSDK::Internal::Type::RequestParameters::Converter
          include HubSpotSDK::Internal::Type::RequestParameters

          attr_accessor campaign_guid: String

          attr_accessor asset_type: String

          attr_reader after: String?

          def after=: (String) -> String

          attr_reader end_date: String?

          def end_date=: (String) -> String

          attr_reader limit: String?

          def limit=: (String) -> String

          attr_reader start_date: String?

          def start_date=: (String) -> String

          def initialize: (
            campaign_guid: String,
            asset_type: String,
            ?after: String,
            ?end_date: String,
            ?limit: String,
            ?start_date: String,
            ?request_options: HubSpotSDK::request_opts
          ) -> void

          def to_hash: -> {
            campaign_guid: String,
            asset_type: String,
            after: String,
            end_date: String,
            limit: String,
            start_date: String,
            request_options: HubSpotSDK::RequestOptions
          }
        end
      end
    end
  end
end
