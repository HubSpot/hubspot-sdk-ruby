module HubSpotSDK
  module Models
    module Marketing
      module Campaigns
        type spend_update_params =
          { campaign_guid: String, spend_id: Integer }
          & HubSpotSDK::Internal::Type::request_parameters

        class SpendUpdateParams < HubSpotSDK::Models::Marketing::PublicSpendItemInput
          extend HubSpotSDK::Internal::Type::RequestParameters::Converter
          include HubSpotSDK::Internal::Type::RequestParameters

          def campaign_guid: -> String

          def campaign_guid=: (String _) -> String

          def spend_id: -> Integer

          def spend_id=: (Integer _) -> Integer

          def initialize: (
            campaign_guid: String,
            spend_id: Integer,
            ?request_options: HubSpotSDK::request_opts
          ) -> void

          def to_hash: -> {
            campaign_guid: String,
            spend_id: Integer,
            request_options: HubSpotSDK::RequestOptions
          }
        end
      end
    end
  end
end
